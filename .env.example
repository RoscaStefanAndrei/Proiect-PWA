# Django Settings
# Generate a new secret key for production: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (optional — defaults to SQLite for local dev)
# Render sets DATABASE_URL automatically when you attach a Postgres database
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Email via Resend (Phase 3 — optional, email notifications disabled without this)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=SmartVest <notifications@yourdomain.com>
SITE_DOMAIN=yourdomain.com

# Web Push (VAPID) — generate with: python manage.py generate_vapid_keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@yourdomain.com

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In (https://developer.apple.com)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_KEY_ID=
